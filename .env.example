# PostgreSQL connection string
DATABASE_URL="postgresql://wcpredictor:wcpredictor@localhost:5432/wcpredictor?schema=public"

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Seed admin credentials (used by prisma/seed.ts)
# Set your own real values in .env (NOT here — this file is committed to git).
ADMIN_EMAIL="admin@worldcup.local"
ADMIN_PASSWORD="change-me-to-a-strong-password"
ADMIN_NAME="Tournament Director"

# ── Email reminders (admin → Reminders tab; src/lib/email.ts) ──
# Free SMTP path — send through an existing mailbox (e.g. a dedicated Gmail with a
# 16-char App Password). Without SMTP_USER/SMTP_PASS the admin UI shows "not
# configured" and sends are a no-op. Defaults target Gmail's SMTP.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""                 # full sending address, e.g. wcpredictor2026@gmail.com
SMTP_PASS=""                 # Google App Password (Account → Security → App passwords), NOT the login password
EMAIL_FROM="World Cup Predictor <wcpredictor2026@gmail.com>"  # use the same address as SMTP_USER

# ── Live Center worker (worker/poll.ts + worker/map-fixtures.ts) ──
# Live scores come from ESPN's open scoreboard API — no proxy or token needed.
# The worker only needs DATABASE_URL (above). Optional knobs:
POLL_INTERVAL_MS="25000"   # poll cadence in ms (default 25000)
# ESPN_BASE="https://site.api.espn.com/apis/site/v2/sports/soccer/fifa.world"  # override only if ESPN moves the endpoint
