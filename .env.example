# PostgreSQL connection string
DATABASE_URL="postgresql://wcpredictor:wcpredictor@localhost:5432/wcpredictor?schema=public"

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Seed admin credentials (used by prisma/seed.ts)
# Set your own real values in .env (NOT here — this file is committed to git).
ADMIN_EMAIL="admin@worldcup.local"
ADMIN_PASSWORD="change-me-to-a-strong-password"
ADMIN_NAME="Tournament Director"

# ── Live Center worker (worker/poll.ts + worker/map-fixtures.ts) ──
# Transport for Sofascore data: "apify" (datacenter-safe, prod) or "direct"
# (residential/local only — raw Sofascore is Cloudflare-403'd from servers).
SOFA_TRANSPORT="direct"
# Required when SOFA_TRANSPORT=apify — runs the azzouzana/sofascore-scraper-pro actor.
APIFY_TOKEN=""
# Poll cadence in ms (default 25000). Lower = more Apify usage.
POLL_INTERVAL_MS="25000"
# Sofascore identifiers — FIFA World Cup tournament id + 2026 season id (rarely change).
WC_TOURNAMENT_ID="16"
WC_SEASON_ID="58210"
# Optional residential proxy for SOFA_TRANSPORT=direct on a server (Option A in worker/README.md).
SOFA_PROXY_URL=""
